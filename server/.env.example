# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/redpulse

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_chars

# ── Gmail OAuth2 (for OTP emails) ───────────────────────
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_USER=your_gmail_address@gmail.com

# ── Client origin (for CORS in production) ──────────────
CLIENT_ORIGIN=http://localhost:5173
